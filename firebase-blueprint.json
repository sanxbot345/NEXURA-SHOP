{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": ["string", "null"] },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number", "description": "Server timestamp" },
        "updatedAt": { "type": "number", "description": "Server timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A user's topup order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "gameId": { "type": "string" },
        "productId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed", "cancelled"] },
        "accountId": { "type": "string" },
        "zoneId": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "gameId", "productId", "amount", "status", "accountId", "paymentMethod", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. Created upon first login."
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders made by users."
    }
  }
}
